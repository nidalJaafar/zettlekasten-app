{
  "expo": {
    "name": "Zettelkasten",
    "slug": "zettelkasten",
    "scheme": "zettelkasten",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111318"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zettelkasten.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111318"
      },
      "package": "com.zettelkasten.mobile",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dba7c8fe-b2b9-47cd-815b-6b7a3ac0ffc2"
      }
    }
  }
}
