{
  "expo": {
    "name": "Zettelkasten",
    "slug": "zettelkasten",
    "scheme": "zettelkasten",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111318"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zettelkasten.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111318"
      },
      "package": "com.zettelkasten.mobile",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ]
  }
}
